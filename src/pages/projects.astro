---
import BaseLayout from "../layouts/BaseLayout.astro";
import projects from "../data/projects.json";

const featured = projects.filter((p) => p.featured);
const other = projects.filter((p) => !p.featured);
---

<BaseLayout title="Projects" sideBarActiveItemID="projects">
  <div class="mb-5 mt-5">
    <div class="text-3xl font-bold">Research projects</div>
  </div>

  {featured.map((project) => (
    <div class="card card-bordered mb-6 bg-base-100 shadow-sm">
      {project.image && (
        <figure>
          <img src={project.image} alt={project.image_alt ?? project.title} class="w-full object-cover max-h-56" />
        </figure>
      )}
      <div class="card-body">
        <div>
          <h2 class="card-title text-xl">{project.title}</h2>
          <div class="text-sm text-base-content/60 mb-2">{project.period} · {project.status}</div>
        </div>
        <p class="text-base-content/80 mb-3">{project.description}</p>
        {project.links && project.links.length > 0 && (
          <div class="card-actions flex flex-wrap gap-2">
            {project.links.map((link: {url: string; label: string}) => (
              <a href={link.url} target="_blank" class="btn btn-sm btn-outline">{link.label}</a>
            ))}
          </div>
        )}
      </div>
    </div>
  ))}

  {other.length > 0 && (
    <>
      <div class="divider my-4"></div>
      {other.map((project) => (
        <div class="card card-bordered mb-4 bg-base-100 shadow-sm">
          <div class="card-body">
            <h2 class="card-title text-lg">{project.title}</h2>
            <div class="text-sm text-base-content/60 mb-2">{project.period} · {project.status}</div>
            <p class="text-base-content/80 mb-2">{project.description}</p>
            {project.links && project.links.length > 0 && (
              <div class="card-actions flex flex-wrap gap-2">
                {project.links.map((link: {url: string; label: string}) => (
                  <a href={link.url} target="_blank" class="btn btn-sm btn-outline">{link.label}</a>
                ))}
              </div>
            )}
          </div>
        </div>
      ))}
    </>
  )}
</BaseLayout>
